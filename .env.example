# ==============================================================================
# Cars24 Brief — Environment Variables
# ==============================================================================
# Copy this file to .env.local (web/) and supabase/.env (functions) and fill in.
# Do NOT commit .env.local or supabase/.env.

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI (required for AI pipeline)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: classify-articles, route-articles, synthesize-stories,
#          generate-daily-brief, generate-competitor-summary
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────────────────
# Supabase (new API key structure)
# ──────────────────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — only for backend/edge functions, NEVER expose to the web app.
# Used by Edge Functions, pg_cron, and any internal scripts.
BACKEND_API_KEY=sb_secret_...

# ──────────────────────────────────────────────────────────────────────────────
# Optional: pipeline tuning
# ──────────────────────────────────────────────────────────────────────────────
# Maximum articles per source per fetch (default: 25)
MAX_ARTICLES_PER_SOURCE=25

# How far back rss-ingest is allowed to look on the first run, in hours (default: 720 = 30d)
FIRST_RUN_LOOKBACK_HOURS=720

# Number of cosine-similar candidate clusters to send to LLM router (default: 5)
ROUTER_CANDIDATE_K=5
